#!/bin/bash

# See https://eioki.eu/2021/01/12/tmux-and-fzf-fuzzy-tmux-session-window-pane-switcher
# Other references:
# https://github.com/junegunn/fzf/wiki/Examples#tmux
# https://www.hschne.at/2020/04/25/creating-a-fuzzy-shell-with-fzf-and-friends.html

# customizable
LIST_DATA="#{session_name} #{window_name} #{pane_current_command} #{pane_current_path}"
TARGET_SPEC="#{session_id}:#{window_id}:#{pane_id}:"

# select pane (pipe directly to fzf to preserve NUL delimiters)
LINE=$(tmux list-panes -a -F "$TARGET_SPEC $LIST_DATA" | while IFS= read -r line; do
  pane_id=$(echo "$line" | cut -d: -f3)
  preview=$(tmux capture-pane -p -t "$pane_id" 2>/dev/null | grep -v '^$' | grep -vE '^\s*[>$%#~]+\s*$' | tail -3 | sed 's/^/  /')
  printf '%s\n%s\0' "$line" "$preview"
done | fzf \
  --read0 \
  --delimiter=: \
  --with-nth 4 \
  --color=hl:2 \
  --preview 'tmux capture-pane -ep -t {3}' \
  --preview-window=right:50%)
args=(${LINE//:/ })
tmux select-pane -t "${args[2]}" && tmux select-window -t "${args[1]}" && tmux switch-client -t "${args[0]}"
